rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && 
        ((exists(userDoc) && get(userDoc).data.role == 'admin') ||
         (request.auth.token.email == "patricioaug@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'status', 'createdAt', 'trialEndsAt']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 128 &&
             data.displayName is string && data.displayName.size() < 128 &&
             data.role in ['admin', 'user'] &&
             data.status in ['trial', 'liberado', 'bloqueado'] &&
             data.createdAt is string &&
             data.trialEndsAt is string;
    }

    // Diagnostic path for connection testing
    match /test/connection {
      allow read: if true;
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile during signup.
      // Only admins can create other users or set roles.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      
      // Users can update their own profile (but not their role or status unless admin).
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.status == resource.data.status) || isAdmin());
    }

    // Logins collection
    match /logins/{loginId} {
      // Only admins can read login history.
      allow read: if isAdmin();
      
      // Any authenticated user can create a login log for themselves.
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Projects collection
    match /projects/{projectId} {
      // Users can read/write their own projects. Admins can read all.
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
